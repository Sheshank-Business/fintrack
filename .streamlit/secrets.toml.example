# Fintrack secrets example (Supabase + optional auth modes)
# 1) Create a Supabase project and copy URL + anon key.
# 2) Choose one auth mode:
#    - passcode: name + shared family passcode
#    - name_only: name only
#    - google: Google OAuth via Streamlit
# 3) Rename this file to secrets.toml for local testing.

[supabase]
url = "https://YOUR_PROJECT_REF.supabase.co"
key = "YOUR_SUPABASE_ANON_KEY"

[app_auth]
mode = "passcode"
shared_passcode = "1234"

# Use this only if mode = "google"
[auth]
redirect_uri = "https://YOUR-APP-NAME.streamlit.app/oauth2callback"

# Use this only if mode = "google"
[google_oauth]
client_id = "YOUR_GOOGLE_CLIENT_ID"
client_secret = "YOUR_GOOGLE_CLIENT_SECRET"
